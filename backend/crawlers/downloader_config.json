{
  "sites": {
    "example_site": {
      "name": "示例站点",
      "base_url": "https://www.example.com",
      "encoding": "utf-8",
      "selectors": {
        "title": "h2",
        "content": "#content",
        "chapter_list": ".mulu a",
        "next_page": ".next-page"
      },
      "url_patterns": {
        "chapter_url_pattern": "/read/{book_id}/{chapter_id}.html",
        "book_url_pattern": "/book/{book_id}.html",
        "relative_url_base": "https://www.example.com"
      },
      "request_config": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
          "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
          "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8",
          "Accept-Encoding": "gzip, deflate, br",
          "Connection": "keep-alive",
          "Upgrade-Insecure-Requests": "1"
        },
        "timeout": 30000,
        "wait_for": "networkidle",
        "delay_between_requests": 3000,
        "retry_count": 3,
        "retry_delay": 5000
      },
      "content_processing": {
        "title_cleanup": {
          "remove_patterns": ["\\s*第\\d+章\\s*", "\\s*章节\\d+\\s*"],
          "replace_patterns": {}
        },
        "content_cleanup": {
          "remove_patterns": [
            "<script[^>]*>.*?</script>",
            "<style[^>]*>.*?</style>",
            "<!--.*?-->",
            "本书来自.*?",
            "更新时间.*?",
            "\\s*广告\\s*",
            "https://[^\\s]*example_site[^\\s]*",
            "http://[^\\s]*example_site[^\\s]*",
            "ｈttps://[^\\s]*",
            "[ｗwWＷ]{3}[•\\.]?[ｈhHＨ][ｅeEＥ][ｔtTＴ][ｕuUＵ][ｓsS][ｈhHＨ][ｕuUＵ][•\\.]?[ｃcCＣ][ｏoOＯ][ｍmMＭ][•\\.]?[ｃcCＣ][ｏoOＯ][ｍmMＭ]",
            "[ｈhHＨ][ｅeEＥ][ｔtTＴ][ｕuUＵ][ｓsS][ｈhHＨ][ｕuUＵ][•\\.]?[ｃcCＣ][ｏoOＯ][ｍmMＭ][•\\.]?[ｃcCＣ][ｏoOＯ][ｍmMＭ]",
            "示例站点",
            "example_site\\.com",
            "www\\.example_site\\.com",
            "和\\*图\\*书",
            "_示例_站点",
            "\\.[cC][oO][mM]"
          ],
          "normalize_whitespace": true
        }
      },
      "file_naming": {
        "pattern": "{title}",
        "max_filename_length": 200,
        "fallback_pattern": "章节_{chapter_id}_{timestamp}"
      }
    },
    "biquge": {
      "name": "笔趣阁",
      "base_url": "https://www.biquge.com",
      "encoding": "utf-8",
      "selectors": {
        "title": ".bookname h1",
        "content": "#content",
        "chapter_list": ".listmain a",
        "next_page": ".next"
      },
      "url_patterns": {
        "chapter_url_pattern": "/book/{book_id}/{chapter_id}.html",
        "book_url_pattern": "/book/{book_id}/",
        "relative_url_base": "https://www.biquge.com"
      },
      "request_config": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
          "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
          "Accept-Language": "zh-CN,zh;q=0.9",
          "Referer": "https://www.biquge.com/"
        },
        "timeout": 25000,
        "wait_for": "domcontentloaded",
        "delay_between_requests": 2000,
        "retry_count": 3,
        "retry_delay": 3000
      },
      "content_processing": {
        "title_cleanup": {
          "remove_patterns": ["笔趣阁", "www\\.biquge\\.com"],
          "replace_patterns": {}
        },
        "content_cleanup": {
          "remove_patterns": [
            "笔趣阁.*?www\\.biquge\\.com",
            "请记住本站域名",
            "一秒记住.*?",
            "<script[^>]*>.*?</script>",
            "<style[^>]*>.*?</style>",
            "<!--.*?-->"
          ],
          "normalize_whitespace": true
        }
      },
      "file_naming": {
        "pattern": "{title}",
        "max_filename_length": 180,
        "fallback_pattern": "章节_{chapter_id}_{timestamp}"
      }
    },
    "17k": {
      "name": "17K小说网",
      "base_url": "https://www.17k.com",
      "encoding": "utf-8",
      "selectors": {
        "title": ".readAreaBox .p",
        "content": ".readAreaBox .p",
        "chapter_list": ".chapter a",
        "next_page": ".page_next"
      },
      "url_patterns": {
        "chapter_url_pattern": "/chapter/{book_id}/{chapter_id}.html",
        "book_url_pattern": "/book/{book_id}.html",
        "relative_url_base": "https://www.17k.com"
      },
      "request_config": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
          "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
          "Accept-Language": "zh-CN,zh;q=0.9",
          "Referer": "https://www.17k.com/"
        },
        "timeout": 30000,
        "wait_for": "networkidle",
        "delay_between_requests": 3000,
        "retry_count": 4,
        "retry_delay": 4000
      },
      "content_processing": {
        "title_cleanup": {
          "remove_patterns": ["17K小说网", "www\\.17k\\.com"],
          "replace_patterns": {}
        },
        "content_cleanup": {
          "remove_patterns": [
            "17K小说网.*?www\\.17k\\.com",
            "手机用户请浏览.*?阅读",
            "<script[^>]*>.*?</script>",
            "<style[^>]*>.*?</style>"
          ],
          "normalize_whitespace": true
        }
      },
      "file_naming": {
        "pattern": "{title}",
        "max_filename_length": 190,
        "fallback_pattern": "章节_{chapter_id}_{timestamp}"
      }
    },
    "qidian": {
      "name": "起点中文网",
      "base_url": "https://www.qidian.com",
      "encoding": "utf-8",
      "selectors": {
        "title": ".j_chapterName",
        "content": ".read-content",
        "chapter_list": ".volume-wrap .cf a",
        "next_page": ".lbf-pagination-next"
      },
      "url_patterns": {
        "book_index": "/book/{book_id}/",
        "chapter": "/chapter/{book_id}/{chapter_id}/"
      },
      "request_config": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
          "Referer": "https://www.qidian.com"
        },
        "timeout": 30000,
        "wait_for": "networkidle",
        "delay_between_requests": 3000,
        "retry_count": 5,
        "retry_delay": 8000
      },
      "content_processing": {
        "title_cleanup": {
          "remove_patterns": ["^第.*?章\\s*"],
          "replace_patterns": {}
        },
        "content_cleanup": {
          "remove_elements": [".ad", ".advertisement"],
          "remove_patterns": ["本章未完.*?"],
          "normalize_whitespace": true
        }
      },
      "file_naming": {
        "pattern": "{title}.txt",
        "fallback_pattern": "章节_{chapter_id}.txt",
        "max_filename_length": 200
      }
    },
    "zongheng": {
      "name": "纵横中文网",
      "base_url": "http://www.zongheng.com",
      "encoding": "utf-8",
      "selectors": {
        "title": ".title_txtbox",
        "content": ".content",
        "chapter_list": ".chapter-list a",
        "next_page": ".next"
      },
      "url_patterns": {
        "book_index": "/book/{book_id}.html",
        "chapter": "/chapter/{book_id}/{chapter_id}.html"
      },
      "request_config": {
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
        },
        "timeout": 25000,
        "wait_for": "networkidle",
        "delay_between_requests": 2500,
        "retry_count": 3,
        "retry_delay": 6000
      },
      "content_processing": {
        "title_cleanup": {
          "remove_patterns": [],
          "replace_patterns": {
            "[\\s]+": " ",
            "[<>:\"/\\\\|?*]": "_"
          }
        },
        "content_cleanup": {
          "remove_elements": [".ad"],
          "remove_patterns": [],
          "normalize_whitespace": true
        }
      },
      "file_naming": {
        "pattern": "{title}.txt",
        "fallback_pattern": "章节_{chapter_id}.txt",
        "max_filename_length": 200
      }
    }
  },
  "global_settings": {
    "default_site": "example_site",
    "output_directory": "./downloads",
    "create_site_subdirectory": true,
    "create_book_subdirectory": true,
    "chapter_content_subdirectory": "章节内容",
    "generate_download_report": true,
    "report_format": "json",
    "log_level": "info",
    "concurrent_downloads": 1,
    "browser_config": {
      "headless": true,
      "viewport": {
        "width": 1280,
        "height": 720
      },
      "locale": "zh-CN",
      "timezone": "Asia/Shanghai"
    }
  },
  "file_templates": {
    "chapter_file": {
      "header": "标题: {title}\nURL: {url}\n获取状态: {status}\n获取时间: {timestamp}\n\n==================================================\n\n",
      "content": "{content}",
      "footer": "\n\n--- 下载完成 ---"
    },
    "download_report": {
      "summary_fields": ["total", "success", "failed", "success_rate", "download_time", "site", "book_title"],
      "detail_fields": ["chapter", "url", "status", "filepath", "retry_count", "timestamp", "error"]
    }
  },
  "advanced_features": {
    "auto_detect_encoding": true,
    "handle_javascript": true,
    "bypass_cloudflare": false,
    "use_proxy": true,
    "proxy_config": {
      "server": "http://127.0.0.1:7899",
      "username": "",
      "password": ""
    },
    "cookie_management": {
      "save_cookies": true,
      "cookie_file": "cookies.json",
      "auto_login": false
    },
    "content_validation": {
      "min_content_length": 50,
      "required_keywords": [],
      "forbidden_keywords": ["404", "页面不存在", "章节不存在"]
    }
  },
  "error_handling": {
    "continue_on_error": true,
    "save_failed_urls": true,
    "failed_urls_file": "failed_downloads.txt",
    "error_log_file": "download_errors.log",
    "max_consecutive_failures": 10
  }
}